<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container py-4">
    <h1 class="h3 mb-3"><%= pageTitle %></h1>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="<%= formAction %>" method="POST" class="card soft-card p-4">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">First Name</label>
          <input class="form-control" type="text" name="firstName" value="<%= author.firstName || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Last Name</label>
          <input class="form-control" type="text" name="lastName" value="<%= author.lastName || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Date of Birth</label>
          <input class="form-control" type="date" name="dob" value="<%= author.dob || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Date of Death</label>
          <input class="form-control" type="date" name="dod" value="<%= author.dod || '' %>" required>
        </div>
        <div class="col-md-4">
          <label class="form-label">Sex</label>
          <select class="form-select" name="sex" required>
            <option value="">Select</option>
            <option value="M" <%= author.sex === 'M' ? 'selected' : '' %>>M</option>
            <option value="F" <%= author.sex === 'F' ? 'selected' : '' %>>F</option>
            <option value="O" <%= author.sex === 'O' ? 'selected' : '' %>>O</option>
          </select>
        </div>
        <div class="col-md-8">
          <label class="form-label">Profession</label>
          <input class="form-control" type="text" name="profession" value="<%= author.profession || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Country</label>
          <input class="form-control" type="text" name="country" value="<%= author.country || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Portrait URL</label>
          <input class="form-control" type="url" name="portrait" value="<%= author.portrait || '' %>" required>
        </div>
        <div class="col-12">
          <label class="form-label">Biography</label>
          <textarea class="form-control" rows="4" name="biography" required><%= author.biography || '' %></textarea>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary" type="submit"><%= submitLabel %></button>
        <a href="/admin/authors" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
