<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container py-4">
    <h1 class="h2 mb-2">Welcome, <%= fullName %></h1>
    <p class="text-muted mb-4">Use the admin tools below to manage authors and quotes.</p>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="card stat-card p-3">
          <h2 class="h6 text-uppercase text-muted">Total Authors</h2>
          <p class="display-6 m-0"><%= totalAuthors %></p>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card stat-card p-3">
          <h2 class="h6 text-uppercase text-muted">Total Quotes</h2>
          <p class="display-6 m-0"><%= totalQuotes %></p>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <a href="/admin/authors" class="btn btn-primary">Manage Authors</a>
      <a href="/admin/quotes" class="btn btn-outline-primary">Manage Quotes</a>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
