<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quotes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h3 m-0">Manage Quotes</h1>
      <a href="/admin/quotes/new" class="btn btn-primary">Add Quote</a>
    </div>

    <div class="card soft-card">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Quote</th>
              <th>Author</th>
              <th>Category</th>
              <th>Likes</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% quotes.forEach((entry) => { %>
              <tr>
                <td>"<%= entry.quote %>"</td>
                <td><%= entry.authorName %></td>
                <td><%= entry.category %></td>
                <td><%= entry.likes %></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-secondary" href="/admin/quotes/<%= entry.quoteId %>/edit">Edit</a>
                  <form action="/admin/quotes/<%= entry.quoteId %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this quote?');">
                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
