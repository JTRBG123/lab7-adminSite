<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container py-4">
    <h1 class="h3 mb-3"><%= pageTitle %></h1>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="<%= formAction %>" method="POST" class="card soft-card p-4">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label">Quote</label>
          <textarea class="form-control" name="quote" rows="3" required><%= quoteEntry.quote || '' %></textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Author</label>
          <select class="form-select" name="authorId" required>
            <option value="">Select an author</option>
            <% authors.forEach((author) => { %>
              <option value="<%= author.authorId %>" <%= String(quoteEntry.authorId) === String(author.authorId) ? 'selected' : '' %>><%= author.authorName %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Category</label>
          <input class="form-control" list="categoryOptions" name="category" value="<%= quoteEntry.category || '' %>" required>
          <datalist id="categoryOptions">
            <% categories.forEach((category) => { %>
              <option value="<%= category %>"></option>
            <% }) %>
          </datalist>
        </div>
        <div class="col-md-3">
          <label class="form-label">Likes</label>
          <input class="form-control" type="number" min="0" step="1" name="likes" value="<%= quoteEntry.likes ?? 0 %>" required>
        </div>
      </div>

      <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary" type="submit"><%= submitLabel %></button>
        <a href="/admin/quotes" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
