<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Authors</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/styles.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/nav') %>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h3 m-0">Manage Authors</h1>
      <a href="/admin/authors/new" class="btn btn-primary">Add Author</a>
    </div>

    <div class="card soft-card">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr>
              <th>Name</th>
              <th>Profession</th>
              <th>Country</th>
              <th>Quotes</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% authors.forEach((author) => { %>
              <tr>
                <td><%= author.firstName %> <%= author.lastName %></td>
                <td><%= author.profession %></td>
                <td><%= author.country %></td>
                <td><%= author.quoteCount %></td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-secondary" href="/admin/authors/<%= author.authorId %>/edit">Edit</a>
                  <form action="/admin/authors/<%= author.authorId %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this author and all related quotes?');">
                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
